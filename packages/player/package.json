{
  "name": "@corm/player",
  "version": "0.1.0",
  "description": "CORM course player — Lit web component with SCORM compatibility, offline-first RxDB persistence, and MQTT sync",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./cmi": {
      "import": "./dist/cmi/index.js",
      "types": "./dist/cmi/index.d.ts"
    },
    "./sequencing": {
      "import": "./dist/sequencing/index.js",
      "types": "./dist/sequencing/index.d.ts"
    },
    "./assessment": {
      "import": "./dist/assessment/index.js",
      "types": "./dist/assessment/index.d.ts"
    },
    "./store": {
      "import": "./dist/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./sync": {
      "import": "./dist/sync/index.js",
      "types": "./dist/sync/index.d.ts"
    },
    "./shim": {
      "import": "./dist/shim/index.js",
      "types": "./dist/shim/index.d.ts"
    },
    "./audit": {
      "import": "./dist/audit/index.js",
      "types": "./dist/audit/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/index.js",
      "types": "./dist/styles/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/styles/theme.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "marked": "^15.0.0"
  },
  "peerDependencies": {
    "rxdb": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "rxdb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/web-components-vite": "^8.4.0",
    "rxdb": "^16.0.0",
    "storybook": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joystick/corm.git",
    "directory": "packages/player"
  }
}
